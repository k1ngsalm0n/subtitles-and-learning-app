# Whisper model: tiny, base, small, medium, large-v3 — or `auto` (default),
# which sizes the model to your machine so it runs well anywhere: `small` on a
# CPU-only box (light, fast enough), and `large-v3` when a capable GPU is present
# (best accuracy, kept fast by the GPU), stepping down on smaller cards. Set a
# concrete name to force one. Note: base/tiny hallucinate badly on Chinese.
WHISPER_MODEL=auto

# Device for the offline NLLB translator: cpu (default) or cuda. It stays on the
# CPU by default so the GPU is free for transcription, which is the heavier job;
# the resident translator would otherwise hog ~4 GB and push Whisper onto the CPU.
# Translating subtitle lines on CPU only costs seconds. Set =cuda only if you
# have plenty of spare VRAM for both models at once.
# TRANSLATE_DEVICE=cuda

# Force a transcription device if auto-detection misbehaves: cpu or cuda.
# WHISPER_DEVICE=cuda

# Word-lookup explanations use any OpenAI-compatible chat API.
# Pick ONE provider and set the three LLM_* vars. If none are set, the app
# falls back to the local NLLB translator (meanings only, no real explanations).
#
# Free hosted (Groq) — get a key at https://console.groq.com/keys :
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_your_key_here
#
# Free + offline (local Ollama — `ollama pull qwen2.5:3b`):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:3b
# LLM_API_KEY=ollama
#
# OpenAI (paid): just set OPENAI_API_KEY and leave the LLM_* vars unset.
# OPENAI_API_KEY=sk-...
